#!/usr/bin/env ruby
# frozen_string_literal: true

require "erb"
require_relative "../lib/ratalada/version"

USAGE = <<~TEXT
  Usage: bin/increment-version <major|minor|patch>
TEXT

segment = ARGV[0]

unless %w[major minor patch].include?(segment)
  warn USAGE
  exit 1
end

current = Ratalada::VERSION
major, minor, patch = current.split(".").map(&:to_i)

case segment
when "major"
  major += 1
  minor = 0
  patch = 0
when "minor"
  minor += 1
  patch = 0
when "patch"
  patch += 1
end

version = "#{major}.#{minor}.#{patch}"

template_path = File.expand_path("../lib/ratalada/version.rb.erb", __dir__)
output_path   = File.expand_path("../lib/ratalada/version.rb", __dir__)

template = ERB.new(File.read(template_path))
result = template.result(binding)

File.write(output_path, result)

puts "#{current} -> #{version}"

# The gemspecs read Ratalada::VERSION directly, so they follow automatically.
# The lockfiles don't — they pin the path gems (ratalada + adapters) at a
# concrete version, so they must be regenerated in lockstep or they drift.
root = File.expand_path("..", __dir__)

gemfiles = [
  File.join(root, "Gemfile"),
  File.join(root, "gemfiles", "grape.gemfile"),
  File.join(root, "gemfiles", "sinatra.gemfile"),
]

gemfiles.each do |gemfile|
  rel = gemfile.sub("#{root}/", "")
  puts "Relocking #{rel}..."
  ok = system({ "BUNDLE_GEMFILE" => gemfile }, "bundle", "install", chdir: root)
  abort "ERROR: bundle install failed for #{rel}" unless ok
end

puts "Bumped and relocked to #{version}"

